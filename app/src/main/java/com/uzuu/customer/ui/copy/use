fun formatDate(input: String): String {
    val instant = Instant.parse(input)
    val zoned = instant.atZone(ZoneId.systemDefault())
    val formatter = DateTimeFormatter.ofPattern("dd/MM/yyyy HH:mm")
    return zoned.format(formatter)
}


