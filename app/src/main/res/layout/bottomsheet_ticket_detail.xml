<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:background="#CCCCCC"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="center"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:strokeColor="@color/blue_border_5"
        app:strokeWidth="1dp">

        <ImageView
            android:id="@+id/img_qr"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:padding="8dp"
            android:contentDescription="QR Code"/>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tv_qr_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Xuất trình mã này khi vào cổng"
        android:textSize="12sp"
        android:textColor="@color/blue_text_secondary"
        android:gravity="center"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/blue_border_2"
        android:layout_marginVertical="16dp"/>

    <TextView
        android:id="@+id/tv_event_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tên sự kiện"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/blue_accent_600"/>

    <TextView
        android:id="@+id/tv_ticket_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Loại vé"
        android:textSize="15sp"
        android:textColor="@color/blue_text_secondary"/>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="● Hợp lệ"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/bg_border_blue_square"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Mã vé"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/blue_text_dark"/>

    <TextView
        android:id="@+id/tv_ticket_code"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Mã: TICKET-001"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:textColor="@color/blue_text_primary"
        android:background="@drawable/bg_border_blue_square"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"/>

    <TextView
        android:id="@+id/tv_used_at"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Dùng lúc: --"
        android:textSize="13sp"
        android:textColor="@color/blue_text_secondary"
        android:visibility="gone"/>

    <Space android:layout_width="match_parent" android:layout_height="16dp"/>

</LinearLayout>