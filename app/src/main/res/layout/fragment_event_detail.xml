<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blue_bg_2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/img_event_detail"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:scaleType="centerCrop"
            android:src="@drawable/avatar" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txt_event_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tên sự kiện"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/blue_accent_600" />

            <TextView
                android:id="@+id/txt_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_border_blue_square"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:text="Ca nhạc"
                android:textSize="13sp"
                android:textColor="@color/blue_primary_600" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/blue_border_2" android:layout_marginVertical="14dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Địa điểm"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/blue_text_dark" />

            <TextView
                android:id="@+id/txt_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Hà Nội"
                android:textSize="15sp" />

            <!-- Thời gian -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Thời gian diễn ra"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/blue_text_dark" />

            <TextView
                android:id="@+id/txt_start_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Bắt đầu: --"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txt_end_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Kết thúc: --"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Bán vé"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/blue_text_dark" />

            <TextView
                android:id="@+id/txt_sale_start"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Mở bán: --"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txt_sale_end"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Kết thúc bán: --"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Trạng thái"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/blue_text_dark" />

            <TextView
                android:id="@+id/txt_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="PENDING"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/event_upcoming" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/blue_border_2" android:layout_marginVertical="14dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mô tả"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/blue_text_dark" />

            <TextView
                android:id="@+id/txt_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Chưa có mô tả."
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.4" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/blue_border_2" android:layout_marginVertical="14dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Các loại vé"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/blue_text_dark" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_ticket_types"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_buy_now"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"
                android:text="Mua ngay"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="17sp"
                app:backgroundTint="@color/blue_primary_550"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </LinearLayout>

</androidx.core.widget.NestedScrollView>