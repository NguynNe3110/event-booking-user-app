<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="16dp">

    <View
        android:id="@+id/handle_bar"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:background="#CCCCCC"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Thông tin sự kiện"
        android:textStyle="bold"
        android:textSize="18sp"/>

    <TextView
        android:id="@+id/txt_nameEvent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sự kiện được tổ chức ở đâu thế mọi người"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FF0000"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/txt_address"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📍Địa điểm: Hà Nội"
        android:layout_marginTop="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Thời gian diễn ra"
        android:layout_marginTop="8dp"
        android:textStyle="bold"
        android:textSize="18sp"/>

    <TextView
        android:id="@+id/txt_dateTimeStart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bắt đầu: 20:00 - 22:00 | 25/03/2026"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/txt_dateTimeEnd"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Kết thúc: 20:00 - 22:00 | 25/03/2026"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/txt_viewDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Xem chi tiết"
        android:textColor="@color/blue_primary_600"
        android:layout_marginTop="8dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginVertical="12dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lựa chọn vé"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:textSize="18sp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_categoryTicket"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="100dp"
        tools:listitem="item_ticket_in_home.xml">

    </androidx.recyclerview.widget.RecyclerView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_addToCart"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="20dp"
        android:text="Thêm vào giỏ"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        app:backgroundTint="@color/blue_primary_550"
        app:cornerRadius="8dp"/>

</LinearLayout>